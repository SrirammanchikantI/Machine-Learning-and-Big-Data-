      <aliases enabled='yes' />
      <column caption='Total Records' datatype='integer' name='[Calculation_1273955788886081536]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT([id])' />
      </column>
      <column caption='Missing Blurb' datatype='real' name='[Calculation_1273955788886220801]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF ISNULL([blurb]) OR [blurb] = &quot;&quot; THEN 1 ELSE 0 END) / COUNT([id])' />
      </column>
      <column caption='Missing Goal' datatype='real' name='[Calculation_1273955788886306818]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF ISNULL([goal]) THEN 1 ELSE 0 END) / COUNT([id])' />
      </column>
      <column caption='Data Completeness Score' datatype='real' name='[Calculation_1273955788886417411]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='1 - (&#13;&#10;  SUM(IF ISNULL([blurb]) THEN 1 ELSE 0 END) +&#13;&#10;  SUM(IF ISNULL([goal]) THEN 1 ELSE 0 END) +&#13;&#10;  SUM(IF ISNULL([category]) THEN 1 ELSE 0 END)&#13;&#10;) / (COUNT([id]) * 3)' />
      </column>
      <column caption='Created Year-Month' datatype='date' name='[Calculation_1273955788886552580]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='DATE(DATETRUNC(&apos;month&apos;, DATEADD(&apos;second&apos;, [created_at], #1970-01-01#)))' />
      </column>
      <column caption='Missing Data' datatype='integer' name='[Calculation_1273955788889894917]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF ISNULL([blurb]) OR ISNULL([goal]) THEN 1 ELSE 0 END)' />
      </column>
      <column caption='Countries Covered' datatype='integer' name='[Calculation_1273955788890308614]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD([country])' />
      </column>
      <column caption='Success Flag' datatype='string' name='[Calculation_1273955788892553223]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [state] = 1 THEN &quot;Successful&quot; ELSE &quot;Failed&quot; END' />
      </column>
      <column caption='Success Rate' datatype='real' name='[Calculation_1273955788892667912]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF [state] = 1 THEN 1 ELSE 0 END) / COUNT([id])' />
      </column>
      <column caption='Funding Percentage' datatype='real' name='[Calculation_1273955788892962825]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[pledged] / [goal]' />
      </column>
      <column caption='Overfunded Flag' datatype='string' name='[Calculation_1273955788893052938]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_1273955788892962825] &gt; 1 THEN &quot;Overfunded&quot; ELSE &quot;Underfunded&quot; END' />
      </column>
      <column caption='Campaign Duration Days' datatype='integer' name='[Calculation_1273955788893163531]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='DATEDIFF(&apos;day&apos;, &#13;&#10;  DATEADD(&apos;second&apos;, [launched_at], #1970-01-01#),&#13;&#10;  DATEADD(&apos;second&apos;, [deadline], #1970-01-01#)&#13;&#10;)' />
      </column>
      <column caption='Goal Tier' datatype='string' name='[Calculation_1273955788893253644]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [goal] &lt; 1000 THEN &quot;&lt; $1K&quot;&#13;&#10;ELSEIF [goal] &lt; 5000 THEN &quot;$1K-$5K&quot;&#13;&#10;ELSEIF [goal] &lt; 10000 THEN &quot;$5K-$10K&quot;&#13;&#10;ELSEIF [goal] &lt; 50000 THEN &quot;$10K-$50K&quot;&#13;&#10;ELSE &quot;$50K+&quot;&#13;&#10;END' />
      </column>
      <column caption='Backers per Day' datatype='real' name='[Calculation_1273955788893388813]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[backers_count] / [Calculation_1273955788893163531]' />
      </column>
      <column caption='Average Funding % KPI' datatype='real' name='[Calculation_1273955788894015502]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([Calculation_1273955788892962825])' />
      </column>
      <column caption='Average Backers KPI' datatype='real' name='[Calculation_1273955788894154767]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([backers_count])' />
      </column>
      <column caption='Scalability Index' datatype='real' name='[Calculation_1273955788904730641]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(&#13;&#10;  (SUM([pledged]) / SUM([goal]) * 40) + &#13;&#10;  (AVG([backers_count]) / 10 * 20) + &#13;&#10;  40&#13;&#10;)' />
      </column>
